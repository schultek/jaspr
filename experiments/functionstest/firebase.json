{
    "hosting": {
        "public": "build/jaspr/web",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "rewrites": [
            {
                "source": "**",
                "function": "render-app"
            }
        ]
    },
    "functions": [
        {
            "source": "functions",
            "codebase": "default",
            "disallowLegacyRuntimeConfig": true,
            "ignore": [
                ".dart_tool",
                ".git",
                "firebase-debug.log",
                "firebase-debug.*.log",
                "*.local"
            ],
            "runtime": "dart3"
        }
    ],
    "emulators": {
        "functions": {
            "port": 5001
        },
        "ui": {
            "enabled": true,
            "port": 4000
        }
    }
}